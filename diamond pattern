<!DOCTYPE html>
<html>
<head>
    <title>Star Diamond Pattern</title>
</head>
<body>

<script>
let rows = 5;

// Upper part
for (let i = 1; i <= rows; i++) {

    // spaces
    for (let s = 1; s <= rows - i; s++) {
        document.write("&nbsp;&nbsp;");
    }

    // stars
    for (let j = 1; j <= (2 * i - 1); j++) {
        document.write("*");
    }

    document.write("<br>");
}

// Lower part
for (let i = rows - 1; i >= 1; i--) {

    // spaces
    for (let s = 1; s <= rows - i; s++) {
        document.write("&nbsp;&nbsp;");
    }

    // stars
    for (let j = 1; j <= (2 * i - 1); j++) {
        document.write("*");
    }

    document.write("<br>");
}
</script>

</body>
</html>
