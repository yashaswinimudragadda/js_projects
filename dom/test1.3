<!DOCTYPE html>
<html lang="en">
    <head>
        <title>handling events</title>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width,initial-scale=1.0">
    </head>
    <body>
      <button id="btn">click me</button>
      <script>
        document.getElementById("btn").addEventListener("click",function(){
            alert("button clicked");
        });
      </script>  
    </body>
</html>
