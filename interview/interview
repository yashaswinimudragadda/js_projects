function calculateAge(dob, targetDate = new Date()) {
    const birthDate = new Date(dob);
    const today = new Date(targetDate);

    let years = today.getFullYear() - birthDate.getFullYear();
    let months = today.getMonth() - birthDate.getMonth();
    let days = today.getDate() - birthDate.getDate();

    // Adjust if the month/day has not been reached yet in the current year
    if (months < 0 || (months === 0 && days < 0)) {
        years--;
        months += (days < 0 ? 11 : 12);
    }

    if (days < 0) {
        // Calculate the number of days in the previous month
        const prevMonth = new Date(today.getFullYear(), today.getMonth(), 0);
        days += prevMonth.getDate();
    }

    return { years, months, days };
}

// Example usage:
const dob = "1995-05-15"; // YYYY-MM-DD
const age = calculateAge(dob, "2026-06-07");

console.log(`Age: ${age.years} years, ${age.months} months, and ${age.days} days.`);
