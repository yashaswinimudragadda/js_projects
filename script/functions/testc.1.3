// print the reverse number with arguments and with retrun
 function reverse(x){
     n=x
     r=0
     sum=0
     while(n>0){
         r=n%10
         sum=sum*10+r
         n=Math.floor(n/10)
     }
     return sum;
 }
 x=parseInt(prompt("enter the value"))
 if(x>0){
     console.log("the reverse number is ",reverse(x))
 }
 else{
     console.log("the valid number")
 }
