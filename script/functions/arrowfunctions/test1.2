//calculating the area and perimeter of the circle
//with out arguments and with arguments

carea=()=>
{
    r=10
    console.log("The area of the circle is: " + Math.floor(Math.PI * r ** 2));
    console.log("The perimeter of the circle is: " + Math.floor(2 * Math.PI * r));
}
