//digits count with out arguments and with return
 digits=()=>{
     n=153
     c=0
     while(n>0){
         n=Math.floor(n/10)
         c++
     }
     return c
 }
 console.log("the no of digits is "+digits())



//calculating eth digits counts with arguments and without return

digits=(n=153)=>{
    c=0
    while(n>0){
        n=Math.floor(n/10)
        c++
    }
    console.log("the no of digits in a number is "+c)
}
digits()






