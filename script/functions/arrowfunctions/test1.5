//calculateing the sum of the digits with out arguments with return 

sum=()=>{
    n=153
    r=0
    sum=0
    while(n>0){
        r=n%10
        sum=sum+r
        n=Math.floor(n/10)
    }
    return sum
}
console.log("the sum of the digits "+sum())




//sum of digits with arguments and without return

sum=(n=153)=>{
    r=0
    sum=0
    while(n>0){
        r=n%10
        sum=sum+r
        n=Math.floor(n/10)
    }
    console.log("the sum of the digits "+sum)
}
sum()



