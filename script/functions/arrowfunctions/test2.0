

//the factorial with out arguments and with return 
factorial=()=>{
    n=5
    i=1
    fac=1
    while(n>=i){
        fac=fac*i
        i++
    }
    return fac
}
    console.log("the given factorial of the given number is "+factorial())

//with arguments without return

factorial=(n=5)=>{
    fac=1
    i=1
    while(n>=i){
        fac=fac*i
        i++
    }
    console.log("the factorial of the given number is "+fac)
}
factorial()


// factorial
//with out argument and with out return
factorial=()=>{
    n=5
    i=1
    fac=1
    while(i<=n){
        fac=fac*i
        i++
    }
    console.log("the factorial of the given number is "+fac)
}
factorial()
