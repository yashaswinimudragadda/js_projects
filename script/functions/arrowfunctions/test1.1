// calculating the value of the area and perimeter of the rectangle 
// with arguments and return

area=(l,b)=>{
    area=l*b
    perimeter=2*(l+b)
    return {
        area:area,
        perimeter:perimeter
    }
}
 result=area(10,20)
 console.log("the area of the rectangle is "+result.area)
 console.log("the perimeter of the rectangle is "+result.perimeter)



// calculating the area of the rectangle and perimeter of the rectangle
// without arguemnts and with return

area=()=>{
    l=10
    b=20
    area=l*b
    perimeter=2*(l+b)
    return {
        area:area, 
        perimeter:perimeter
    }
}

rectangle=area()
console.log("area of the rectangle is "+rectangle.area)
console.log("perimeter of the rectangle is "+rectangle.perimeter)

// calculating the area and perimeter of the rectangle with arguments 
// without return
area=(x,y)=>{
    console.log("area of the rectangle is "+(x*y))
    console.log("perimeter of the rectangle is "+(2*(x+y)))
}
area(10,20)


