//parlindrome with out arguments and without return

parlindrome=()=>{
    n=151
    r=0
    sum=0
    t=n
    while(n>0){
        r=n%10
        sum=sum*10+r
        n=Math.floor(n/10)
    }
    result=(t===sum)?"the given number is parlindrome":"the given number is not parlindrome";

    console.log(result)
}
parlindrome()
