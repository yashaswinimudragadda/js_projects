//cyclic number without argument and with arguments
function cyclic(){
    n=parseInt(prompt("enter the value here "))
    if(n>0){
        l=Math.floor(n%10)
        while(n>0){
            f=n%10
            n=Math.floor(n/10)
        }
        console.log("the given number's last digit is  ",l)
        console.log("the given number's first digit is ",f)
         if(l==f){
             console.log("the given number is cylic number.")
         }
         else{
             console.log("the given number is not cyclic number.")
         }
    }
    else{
        console.log("error:try again")
    }
    
}
cyclic()
