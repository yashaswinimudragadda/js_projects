// calculating eht area of the perimeter of rectangle 
// with out arguments and without returns
function perimeterOfRec(){
    l=parseInt(prompt("enter length of the rectangle: "))
    b=parseInt(prompt("enter breadth of the rectangle: "))
    perimeter = 2*(l+b)
    console.log("the perimeter of the rectangle ",perimeter)
}
perimeterOfRec();
