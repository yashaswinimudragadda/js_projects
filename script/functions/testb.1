// calculating sum of the digits in the given number with out arguments and iwthout return type

function sum(){
    n=parseInt(prompt("enter the number"))
    sum=0,r=0;
    if(n>0){
        while(n>0){
            r=n%10
            sum=sum+r
            n=Math.floor(n/10)
        }
        console.log("the sum of the digits in the given number is ",sum)
    }
    else{
        console.log("the entered number is invalid please try again")
    }
}
sum();
