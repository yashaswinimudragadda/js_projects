//print the reverse number of the given number
// with arguments and without return
function reverse(x){
    r=0
    n=x
    sum=0
    while(n>0){
        r=n%10
        sum=sum*10+r
        n=Math.floor(n/10)
    }
    console.log("the reverse number is ",sum)
}
x=parseInt(prompt("enter the value here "))
if(x>0){
    reverse(x)
}
else{
    console.log("error:try again.")
}
