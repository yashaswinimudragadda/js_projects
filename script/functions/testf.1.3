//calculating the factorial value with arguments and with out arguments

function factorial(x){
    n=x
    i=1
    fac=1
    while(i<=n){
        fac=fac*i
        i++
    }
    console.log("the given value is ",n)
    return fac
}
x=parseInt(prompt("enter the value here"))
if(x>0){
    console.log("the factorial of the given number ",factorial(x))
}
else{
    console.log("error: try again.")
}
