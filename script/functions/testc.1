// print the reverse number with out argument and with out return
function reverse(){
    n=parseInt(prompt("enter the number"))
    if(n>0){
        sum=0
        r=0
        while(n>0){
           r=n%10
           sum=sum*10+r
           n=Math.floor(n/10)
        }
        console.log("the reverse number of the given number",n," is ",sum)
    }
    else{
        console.log("enter the valid number.")
    }
}
reverse()
