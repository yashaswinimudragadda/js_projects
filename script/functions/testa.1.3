// calculating the  digit count with arguments and return type
function count(x){
    n=x
    c=0
    while(n>0){
        n=Math.floor(n/10)
        c=c+1
    }
    return c
}
x=parseInt(prompt("enter the value: "))
if(x>0){
    console.log("the count of the digit is ",count(x))
}
else{
    console.log("enter the valid number")
}
