//calculating factorial with out arguments and without retrun
function factorial(){
    n=parseInt(prompt("enter the value"))
    if(n>0){
        i=1
        fac=1
        while(i<=n){
            fac=fac*i
            i++
        }
        console.log("the given number is ",n)
        console.log("the factorial of the given number is ",fac)
    }
}
factorial()
