// check the parlindrome of the given number with out argumetns and without return 
function parlindrome(){
    n=parseInt(prompt("enter the number here "))
    if(n>0){
        r=0
        sum=0
        t=n
        while(n>0){
            r=n%10
            sum=sum*10+r
            n=Math.floor(n/10)
        }
        console.log("the given number is ",t)
         if(t==sum){
             console.log("the given number is parlindrome.")
         }
         else{
             console.log("the given number is not parlindrome.")
         }
    }
    else{
        console.log("error: try again")
    }
}
parlindrome()
