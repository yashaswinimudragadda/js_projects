function prime(x){
    n=x
    for(i=2;i<=n;i++)
    {
    isprime=true
    for(j=2;j<=Math.sqrt(i);j++)
    {
    if(i%j === 0)
    {
        isprime=false
        break
    }
    }
    if(isprime)
    {
    console.log(i," is a prime number.")    
    }
    else
    {
        console.log(i," is  not  a prime number.")
    }
    
    
}
}
x=parseInt(prompt("enter the value here "))
if(x>=2){
    prime(x)
}
else{
    console.log("error:try again.")
}
