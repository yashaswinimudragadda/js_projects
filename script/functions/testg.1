//calculating the fabnociss series
// without arguments and without return
function fab(){
    n=parseInt(prompt("enter the value here"))
    if(n>0){
        a=0
        b=1
        i=0
        while(i<=n){
            console.log(a)
            c=a+b
            a=b
            b=c
            i++
        }
    }
    else{
        console.log("error:try again")
    }
}
fab()
