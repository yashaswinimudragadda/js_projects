// calculating eht perimeter of the rectangle
// with argument and with return type

function perimeter(x,y){
    l=x
    b=y
    perimeter=2*(l+b)
    return perimeter
}
x=parseInt(prompt("enter the length value: "))
y= parseInt(prompt("enter the breadth value: "))

console.log("the perimeter of the rectangle is ",perimeter(x,y))
