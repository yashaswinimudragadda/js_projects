function armstrong(x) {
     n = x;
     sum = 0;
    t = n;

    while (n > 0) {
         r = n % 10;     // Get the last digit
        sum = sum + r**3;   // Cube it and add to sum
        n = Math.floor(n/10); // Remove the last digit
    }

    // Returning a string so the caller can decide what to do with it
    if (sum === t) {
        return "the given number is armstrong";
    } else {
        return "the given number is not armstrong.";
    }
}

