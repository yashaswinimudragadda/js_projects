class A
{
    reverse=(n=153)=>{
        let r=0
        let sum=0
        while(n>0){
            r=n%10
            sum=sum*10+r
            n=Math.floor(n/10)
        }
        console.log("the reverse number is "+sum)
    }
}
class B extends A
{
    reverseString=(n="100")=>
    {
        console.log("the reverse string is "+n.split('').reverse().join(''))
    }
}
b=new B()
b.reverse()
b.reverseString()
