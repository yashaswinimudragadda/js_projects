class A
{
    count=(n=153)=>{
         let c=0
        while(n>0){
            n=Math.floor(n/10)
            c++
        }
        console.log("the count of the digits = ",c)
    }
}
class B extends A
{
    sum=(n=153)=>{
       let  r=0
        let sum=0
        while(n>0){
            r=n%10
            sum=sum+r
            n=Math.floor(n/10)
        }
        console.log("the sum of the digits = "+sum)
    }
}

b=new B()
b.count()
b.sum()
