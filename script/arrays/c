a = [10, 20, 30, 40, 50];
max = a[0]; // Initialize with the first element of 'a'
min = a[0];

for (i = 0; i < a.length; i++) {
    console.log("Current element:", a[i]);
    
    if (a[i] > max) {
        max = a[i];
    } else if (a[i] < min) {
        min = a[i];
    }
}

console.log("Final Max = ", max);
console.log("Final Min = ", min);
