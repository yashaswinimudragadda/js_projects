//find the sum of only even numbers

function Evensum(arr){
    let Esum=0;
    for(let i=0;i<=arr.length;i++){
        if(arr[i]%2==0){
            Esum=Esum+1;
        }
    }
    return Esum;
}

function Oddsum(arr){
    let Osum=0;
    for(let i=0;i<=arr.length;i++){
        if(arr[i]%2!=0){
            Osum=Osum+1;
        }
    }
    return Osum;
}

